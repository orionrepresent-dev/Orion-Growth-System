# Orion Growth Studio - Caddyfile
# Domínio: studio-app.orionconsultoria.cloud
# SSL automático via Let's Encrypt

{
    email pablo@orionconsultoria.com.br
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

studio-app.orionconsultoria.cloud {
    encode gzip

    # Logs
    log {
        output file /var/log/caddy/studio-app.log
        format json
    }

    # Headers de segurança
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Proxy para a aplicação Next.js
    reverse_proxy studio-app:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}
