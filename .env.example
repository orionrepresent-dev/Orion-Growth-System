# ===========================================
# ORION GROWTH STUDIO - CONFIGURAÇÃO DE APIs
# ===========================================
# Copie este arquivo para .env.local e preencha com suas chaves

# ====================
# EMAIL (RESEND)
# ====================
# 1. Acesse: https://resend.com
# 2. Crie uma conta gratuita
# 3. Vá em API Keys > Create API Key
# 4. Cole a chave abaixo

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email remetente (use o domínio verificado na Resend)
# Em desenvolvimento, use: onboarding@resend.dev
EMAIL_FROM=onboarding@resend.dev

# Email do administrador (onde recebe notificações de novos leads)
ADMIN_EMAIL=pablo@orionconsultoria.com.br

# ====================
# WHATSAPP (Z-API)
# ====================
# 1. Acesse: https://z-api.io
# 2. Crie uma conta e conecte seu WhatsApp Business
# 3. Copie o Instance ID e Token do painel

ZAPI_INSTANCE=sua-instance-id
ZAPI_TOKEN=seu-token

# ====================
# DATABASE (OPCIONAL)
# ====================
# Para persistência de dados com Prisma
# PostgreSQL recomendado para produção

DATABASE_URL="postgresql://user:password@localhost:5432/orion_growth"

# ====================
# NEXTAUTH (OPCIONAL)
# ====================
# Para autenticação de usuários

NEXTAUTH_SECRET=gerar-uma-chave-aleatoria-aqui
NEXTAUTH_URL=http://localhost:3000
